# Server-side model key (required for hosted reshapes)
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (Neon/Supabase/Fly PG). Setting this turns AUTH ON.
DATABASE_URL=postgres://user:pass@host/db

# Transactional email for magic links (omit -> dev links in the response)
RESEND_API_KEY=re_...
FROM_EMAIL=Clay <login@yourdomain.com>

# Absolute origin used inside emailed links (your deployed URL)
APP_ORIGIN=https://yourdomain.com

# Local-only alternatives:
# AUTH=dev            in-memory accounts, magic links returned directly
# STATIC_DIR=packages/shell/dist   serve the built shell same-origin
