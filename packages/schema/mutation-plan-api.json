{
  "$comment": "SIMPLIFIED MutationPlan for API structured output (G1/ADR-013). The API requires additionalProperties:false on EVERY object AND caps grammar complexity, so the variable-shape nested parts (migration, each declared_queries entry) are carried as JSON STRINGS here and hydrated + Zod-validated client-side (see client.ts hydrateApiPlan). The grammar guarantees only parseability; index.ts is the correctness gate. Subset rules: every object closed; nullability via anyOf; no $comment on the wire (client strips it). Keep byte-stable for grammar caching.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api": { "type": "number" },
    "summary": { "type": "string" },
    "user_facing_diff": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "enum": ["add_field", "change_field", "add_panel", "change_panel", "remove_panel", "add_status", "add_computed", "add_chart"] },
          "detail": { "type": "string" }
        },
        "required": ["kind", "detail"]
      }
    },
    "clarifying_question": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "migration": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "panel_id": { "type": "string" },
          "title": { "type": "string" },
          "placement": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "region": { "type": "string", "enum": ["top", "main", "side"] },
              "order": { "type": "number" }
            },
            "required": ["region", "order"]
          },
          "code": { "type": "string" },
          "declared_queries": { "type": "array", "items": { "type": "string" } },
          "declared_writes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["panel_id", "title", "placement", "code", "declared_queries"]
      }
    },
    "remove_panels": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number" }
  },
  "required": ["api", "summary", "user_facing_diff", "clarifying_question", "assumptions", "migration", "panels", "remove_panels", "confidence"]
}
