{
  "$comment": "SIMPLIFIED MutationPlan for API structured output (G1/ADR-013). The grammar guarantees only PARSEABILITY; full correctness is the Zod schema (index.ts) client-side. Deliberately loose: migration ops, queries, and placement are bare objects so the compiled grammar stays small (the API enforces a grammar-complexity cap). Subset rules: nullability via anyOf (no type arrays); no $comment on the wire (the client strips it). Keep byte-stable for grammar caching.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "api": { "type": "number" },
    "summary": { "type": "string" },
    "user_facing_diff": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string", "enum": ["add_field", "change_field", "add_panel", "change_panel", "remove_panel", "add_status", "add_computed", "add_chart"] },
          "detail": { "type": "string" }
        },
        "required": ["kind", "detail"]
      }
    },
    "clarifying_question": { "anyOf": [{ "type": "string" }, { "type": "null" }] },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "migration": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "operations": { "type": "array", "items": { "type": "object" } },
            "inverse": { "type": "array", "items": { "type": "object" } }
          },
          "required": ["operations", "inverse"]
        },
        { "type": "null" }
      ]
    },
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "panel_id": { "type": "string" },
          "title": { "type": "string" },
          "placement": { "type": "object" },
          "code": { "type": "string" },
          "declared_queries": { "type": "array", "items": { "type": "object" } },
          "declared_writes": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["panel_id", "title", "placement", "code", "declared_queries"]
      }
    },
    "remove_panels": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number" }
  },
  "required": ["api", "summary", "user_facing_diff", "clarifying_question", "assumptions", "migration", "panels", "remove_panels", "confidence"]
}
